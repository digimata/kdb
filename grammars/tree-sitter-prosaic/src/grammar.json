{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "prosaic",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "_line"
          },
          {
            "type": "SYMBOL",
            "name": "_newline"
          }
        ]
      }
    },
    "_newline": {
      "type": "PATTERN",
      "value": "\\n"
    },
    "_line": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "comment"
        },
        {
          "type": "SYMBOL",
          "name": "block_label_line"
        },
        {
          "type": "SYMBOL",
          "name": "statement"
        }
      ]
    },
    "comment": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "/*"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "annotation"
              },
              {
                "type": "PATTERN",
                "value": "[^*()/]"
              },
              {
                "type": "PATTERN",
                "value": "\\*[^/]"
              },
              {
                "type": "PATTERN",
                "value": "\\/"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "*/"
        }
      ]
    },
    "annotation": {
      "type": "PATTERN",
      "value": "\\([^)]+\\)"
    },
    "block_label_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "block_label"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_token"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "block_label": {
      "type": "PATTERN",
      "value": "[a-z_]+:"
    },
    "statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_token"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_token"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "_token": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "control_keyword"
        },
        {
          "type": "SYMBOL",
          "name": "action_verb"
        },
        {
          "type": "SYMBOL",
          "name": "template_var"
        },
        {
          "type": "SYMBOL",
          "name": "file_path"
        },
        {
          "type": "SYMBOL",
          "name": "operator"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "SYMBOL",
          "name": "word"
        }
      ]
    },
    "control_keyword": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "for each"
        },
        {
          "type": "STRING",
          "value": "for"
        },
        {
          "type": "STRING",
          "value": "if"
        },
        {
          "type": "STRING",
          "value": "in"
        },
        {
          "type": "STRING",
          "value": "break"
        }
      ]
    },
    "action_verb": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "copy"
        },
        {
          "type": "STRING",
          "value": "write"
        },
        {
          "type": "STRING",
          "value": "create"
        },
        {
          "type": "STRING",
          "value": "mark"
        },
        {
          "type": "STRING",
          "value": "check"
        },
        {
          "type": "STRING",
          "value": "print"
        },
        {
          "type": "STRING",
          "value": "list"
        },
        {
          "type": "STRING",
          "value": "update"
        },
        {
          "type": "STRING",
          "value": "sort"
        },
        {
          "type": "STRING",
          "value": "tag"
        },
        {
          "type": "STRING",
          "value": "assign"
        },
        {
          "type": "STRING",
          "value": "prune"
        },
        {
          "type": "STRING",
          "value": "classify"
        },
        {
          "type": "STRING",
          "value": "pick"
        },
        {
          "type": "STRING",
          "value": "take"
        },
        {
          "type": "STRING",
          "value": "allocate"
        },
        {
          "type": "STRING",
          "value": "link"
        },
        {
          "type": "STRING",
          "value": "group"
        },
        {
          "type": "STRING",
          "value": "inventory"
        },
        {
          "type": "STRING",
          "value": "note"
        },
        {
          "type": "STRING",
          "value": "review"
        }
      ]
    },
    "template_var": {
      "type": "PATTERN",
      "value": "\\{[a-zA-Z_][a-zA-Z0-9_.]*\\}"
    },
    "file_path": {
      "type": "PATTERN",
      "value": "\\.[a-zA-Z0-9_/{}.-]+"
    },
    "operator": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "→"
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "STRING",
          "value": "×"
        }
      ]
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[a-zA-Z_][a-zA-Z0-9_]*:"
    },
    "word": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": -1,
        "content": {
          "type": "PATTERN",
          "value": "[^\\s{}\\n]+"
        }
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t]"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}